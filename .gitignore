# Logs
server.log
logs/
*.log

# Runtime data (generated at run-time, not source-controlled)
vetinari_memory.db
vetinari_episodes.db
vetinari_quality_scores.db
vetinari_checkpoints/
model_cache/
.vetinari/
outputs/
!outputs/release/.gitkeep
# `projects/` is the runtime workspace dir, but a `projects/` subdir may
# also appear inside the UI tree (Svelte components grouped by feature) —
# unignore that path explicitly so the components ship with the bundle.
projects/
!ui/svelte/src/components/projects/
training_data.jsonl

# IDE
.vscode/
.idea/
*.swp
*.swo

# Security - encryption keys must never be committed
vault/.key
vault/*.key

# Runtime storage directories
subtasks/
dry_run_demo_pkg/

# Local model files (GGUF weights etc.) — top-level only, not vetinari/models/
/models/

# Internal AI workbench material. These are local/private workflow assets, not
