ui/svelte/models/

# AI audit probe scratch. Keep durable markdown/json evidence, not runtime caches.
.ai-codex/**/.probe_state/
.ai-codex/**/__pycache__/
.ai-codex/**/PROBE-RUN/
.ai-codex/**/ROUND-*-PROBE-RUN/
.ai-codex/**/plan_cache/
