# Vetinari Environment Variables Configuration
# Copy this file to .env and fill in your values

# ===================
# Cloud Provider API Keys
# ===================

# HuggingFace Inference API (free tier)
# Get your token at: https://huggingface.co/settings/tokens
HF_HUB_TOKEN=

# Replicate API (free credits available)
# Get your token at: https://replicate.com/account/api-token
REPLICATE_API_TOKEN=

# Claude (Anthropic) API
# Get your API key at: https://console.anthropic.com/
CLAUDE_API_KEY=

# Gemini (Google AI) API
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ===================
# Ponder Configuration
# ===================

# Enable/disable model search integration (default: true)
ENABLE_PONDER_MODEL_SEARCH=true

# Cloud weight for augmented ranking (0.0 - 0.5, default: 0.20)
# Higher values give more influence to cloud provider relevance signals
PONDER_CLOUD_WEIGHT=0.20

# ===================
# Plan Mode Configuration
# ===================

# Enable Plan Mode (default: true - plan-first for all tasks)
# Set to false to disable plan-first orchestration
PLAN_MODE_ENABLE=true

# Default plan mode for all tasks (default: true)
# When enabled, all tasks go through plan generation first
PLAN_MODE_DEFAULT=true

# Enable dry-run mode (default: false)
# When enabled, plans are generated but not executed automatically
DRY_RUN_ENABLED=false

# Risk threshold for auto-approval in dry-run mode (0.0 - 1.0, default: 0.25)
# Plans with risk_score <= threshold are auto-approved
DRY_RUN_RISK_THRESHOLD=0.25

# Maximum depth for recursive plan decomposition (default: 16)
PLAN_DEPTH_CAP=16

# Maximum number of plan candidates to generate (default: 3)
PLAN_MAX_CANDIDATES=3

# Admin token for plan management endpoints
# Required for /api/plan/* endpoints
PLAN_ADMIN_TOKEN=

# Memory store configuration
# Path to SQLite database for plan history (default: ./vetinari_memory.db)
PLAN_MEMORY_DB_PATH=./vetinari_memory.db

# Use JSON fallback if SQLite is unavailable (default: false)
PLAN_USE_JSON_FALLBACK=false

# Plan retention in days (default: 90)
# Older plans will be pruned automatically
PLAN_RETENTION_DAYS=90

# ===================
# LM Studio Configuration
# ===================

# LM Studio host URL
LM_STUDIO_HOST=http://localhost:1234

# API Token for LM Studio (if required)
LM_STUDIO_API_TOKEN=
