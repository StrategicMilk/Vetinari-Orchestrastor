# Vetinari Environment Configuration — Example
# Copy to .env and edit as needed.

# === LM Studio ===
# URL where LM Studio is running (localhost or remote IP)
LM_STUDIO_HOST=http://localhost:1234
# Optional API token if required by your LM Studio setup
LM_STUDIO_API_TOKEN=

# === Data Directory ===
# Where Vetinari stores plans, memory, training data, etc.
# Defaults to the project directory if not set.
# VETINARI_DATA_DIR=/path/to/your/data

# === Plan Mode ===
PLAN_MODE_ENABLE=true
PLAN_MODE_DEFAULT=true
PLAN_DEPTH_CAP=16

# === Execution ===
# EXECUTION_MODE=execution   # planning | execution
# VERIFICATION_LEVEL=standard  # none | basic | standard | strict
# MAX_CONCURRENT_TASKS=4

# === Vetinari API ===
# Internal API token for admin endpoints (leave blank for local-only access)
VETINARI_API_TOKEN=

# === External Model Providers (optional) ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# COHERE_API_KEY=

# === Feature Flags ===
# ENABLE_EXTERNAL_DISCOVERY=true
