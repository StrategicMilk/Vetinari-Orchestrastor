# Vetinari Environment Variables Configuration
# Copy this file to .env and fill in your values

# ===================
# Cloud Provider API Keys
# ===================

# HuggingFace Inference API (free tier)
# Get your token at: https://huggingface.co/settings/tokens
HF_HUB_TOKEN=

# Replicate API (free credits available)
# Get your token at: https://replicate.com/account/api-token
REPLICATE_API_TOKEN=

# Claude (Anthropic) API
# Get your API key at: https://console.anthropic.com/
CLAUDE_API_KEY=

# Gemini (Google AI) API
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ===================
# Ponder Configuration
# ===================

# Enable/disable model search integration (default: true)
ENABLE_PONDER_MODEL_SEARCH=true

# Cloud weight for augmented ranking (0.0 - 0.5, default: 0.20)
# Higher values give more influence to cloud provider relevance signals
PONDER_CLOUD_WEIGHT=0.20

# ===================
# LM Studio Configuration
# ===================

# LM Studio host URL
LM_STUDIO_HOST=http://localhost:1234

# API Token for LM Studio (if required)
LM_STUDIO_API_TOKEN=
