# Vetinari Environment Variables Configuration
# Copy this file to .env and fill in your values
#
# Paste credential values as raw tokens without surrounding quotes. If a shell or
# dotenv loader preserves quotes, provider readiness checks may see the quotes as
# part of the token.

# ===================
# Cloud Provider API Keys
# ===================

# HuggingFace Inference API (free tier)
# Get your token at: https://huggingface.co/settings/tokens
HF_HUB_TOKEN=

# Replicate API (free credits available)
# Get your token at: https://replicate.com/account/api-token
REPLICATE_API_TOKEN=

# Claude (Anthropic) API
# Get your API key at: https://console.anthropic.com/
CLAUDE_API_KEY=

# Gemini (Google AI) API
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API (for cloud model routing)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API (for cloud model routing)
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ===================
# Safety / Guardrails
# ===================

# Model to use for LLM-based guardrail checks (optional, regex checks always run)
GUARDRAIL_MODEL=

# ===================
# Ponder Configuration
# ===================

# Enable/disable model search integration (default: true)
ENABLE_PONDER_MODEL_SEARCH=true

# Cloud weight for augmented ranking (0.0 - 0.5, default: 0.20)
# Higher values give more influence to cloud provider relevance signals
PONDER_CLOUD_WEIGHT=0.20

# ===================
# Plan Mode Configuration
# ===================

# Enable Plan Mode (default: true - plan-first for all tasks)
# Set to false to disable plan-first orchestration
PLAN_MODE_ENABLE=true

# Default plan mode for all tasks (default: true)
# When enabled, all tasks go through plan generation first
PLAN_MODE_DEFAULT=true

# Enable dry-run mode (default: false)
# When enabled, plans are generated but not executed automatically
DRY_RUN_ENABLED=false

# Risk threshold for auto-approval in dry-run mode (0.0 - 1.0, default: 0.25)
# Plans with risk_score <= threshold are auto-approved
DRY_RUN_RISK_THRESHOLD=0.25

# Maximum depth for recursive plan decomposition (default: 16)
PLAN_DEPTH_CAP=16

# Maximum number of plan candidates to generate (default: 3)
PLAN_MAX_CANDIDATES=3

# Live Litestar admin guard authority. Required before exposing admin/control
# routes beyond trusted localhost use. Send as X-Admin-Token or
# Authorization: Bearer <token>.
VETINARI_ADMIN_TOKEN=

# Legacy plan-memory/status flag. This is not the Litestar admin guard token.
PLAN_ADMIN_TOKEN=

# Memory store configuration
# Path to SQLite database for plan history (default: ./vetinari_memory.db)
PLAN_MEMORY_DB_PATH=./vetinari_memory.db

# Use JSON fallback if SQLite is unavailable (default: false)
PLAN_USE_JSON_FALLBACK=false

# Plan retention in days (default: 90)
# Older plans will be pruned automatically
PLAN_RETENTION_DAYS=90

# ===================
# Explainability Configuration
# ===================

# Enable explainability (default: true)
# When enabled, plans will include explanations and rationales
EXPLAINABILITY_ENABLED=true

# ===================
# Local Inference Configuration (llama-cpp-python)
# ===================

# Path to the directory containing GGUF model files
# Example: /home/user/models  or  C:\models
VETINARI_MODELS_DIR=

# Path to native Hugging Face-format model directories used by vLLM/NIM flows
# Example: /home/user/models/native  or  C:\models\native
VETINARI_NATIVE_MODELS_DIR=

# Number of transformer layers to offload to GPU (-1 = all layers, 0 = CPU only)
VETINARI_GPU_LAYERS=-1

# Default context window size in tokens (overrides per-model defaults)
# Most modern GGUF models support 8192+; set lower if VRAM-constrained
VETINARI_CONTEXT_LENGTH=8192

# OpenAI-compatible local inference server endpoints
# vLLM is the preferred native-model backend; NIM is the secondary native backend
VETINARI_VLLM_ENDPOINT=http://localhost:8000
VETINARI_NIM_ENDPOINT=http://localhost:8001

# ===================
# Image Generation (diffusers, optional: pip install vetinari[image])
# ===================

# Path to directory containing diffusion model directories (SDXL, FLUX, etc.)
VETINARI_IMAGE_MODELS_DIR=

# Enable/disable image generation (default: true if diffusers installed)
VETINARI_IMAGE_ENABLED=true

# ===================
# Search Configuration (SearXNG)
# ===================

# SearXNG URL (run via: docker compose -f docker/docker-compose.yml up -d)
SEARXNG_URL=http://localhost:8888

# Search backend: searxng (default, self-hosted), duckduckgo (fallback, rate-limited)
VETINARI_SEARCH_BACKEND=searxng

# ===================
# Rate Limiting
# ===================

# Requests per minute per IP address (default: 60)
VETINARI_RATE_LIMIT_RPM=60

# Burst capacity — max requests allowed in rapid succession (default: 10)
VETINARI_RATE_LIMIT_BURST=10

# ===================
# Training Data
# ===================

# Path to JSONL training data file (default: ./training_data.jsonl)
VETINARI_TRAINING_DATA_PATH=./training_data.jsonl

# ===================
# Instance Lock
# ===================

# Path to PID file preventing duplicate instances (default: .vetinari.pid)
VETINARI_PID_FILE=.vetinari.pid
