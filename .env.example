# Vetinari Environment Configuration
# Copy to .env and adjust values as needed.

# ── LM Studio / API ──────────────────────────────────────────────────────────
LM_STUDIO_HOST=http://localhost:1234
LM_STUDIO_API_TOKEN=
VETINARI_DEFAULT_MODEL=
VETINARI_API_TOKEN=

# ── Web UI ────────────────────────────────────────────────────────────────────
VETINARI_WEB_PORT=5000
VETINARI_WEB_HOST=0.0.0.0
FLASK_DEBUG=false

# ── Admin Security ────────────────────────────────────────────────────────────
VETINARI_ADMIN_TOKEN=

# ── Execution / Planning ─────────────────────────────────────────────────────
PLAN_DEPTH_CAP=16
PLAN_MAX_CANDIDATES=3
PLAN_MODE_ENABLE=true
PLAN_MODE_DEFAULT=true
DRY_RUN_ENABLED=false
DRY_RUN_RISK_THRESHOLD=0.25
EXECUTION_MODE=execution
VERIFICATION_LEVEL=standard

# ── Coding Bridge ────────────────────────────────────────────────────────────
CODING_BRIDGE_HOST=http://localhost:4096
CODING_BRIDGE_ENABLED=false
CODING_BRIDGE_ENDPOINT=http://localhost:4096
CODE_BRIDGE_ENDPOINT=http://localhost:4096
CODE_BRIDGE_API_KEY=
CODE_BRIDGE_TIMEOUT=30
CODING_AGENT_ENABLED=true
CODING_AGENT_USE_BRIDGE=false

# ── Image Generation (Stable Diffusion) ──────────────────────────────────────
SD_WEBUI_HOST=http://localhost:7860
SD_WEBUI_ENABLED=false

# ── External Services ────────────────────────────────────────────────────────
ELASTICSEARCH_HOST=http://localhost:9200
SPLUNK_HOST=http://localhost:8088

# ── Cloud Provider API Keys (optional) ───────────────────────────────────────
CLAUDE_API_KEY=
GEMINI_API_KEY=
SERPAPI_KEY=
TAVILY_API_KEY=

# ── Memory / Database ────────────────────────────────────────────────────────
VETINARI_MEMORY_DB=./vetinari_memory.db
VETINARI_ENABLE_SEMANTIC_MEMORY=false
VETINARI_EPISODE_DB=./vetinari_episodes.db
VETINARI_MAX_EPISODES=10000
VETINARI_QUALITY_DB=./vetinari_quality_scores.db
PLAN_MEMORY_DB_PATH=./vetinari_memory.db
PLAN_RETENTION_DAYS=90
PLAN_ADMIN_TOKEN=
PLAN_USE_JSON_FALLBACK=false
MEMORY_BACKEND_MODE=dual
OC_MEMORY_PATH=./.vetinari/mnemoria
MNEMOSYNE_PATH=./.vetinari/mnemosyne
MEMORY_PRIMARY_READ=oc
MEMORY_DEDUP_ENABLED=true
MEMORY_MERGE_LIMIT=100

# ── Model Discovery / Routing ────────────────────────────────────────────────
ENABLE_EXTERNAL_DISCOVERY=true
ENABLE_PONDER_MODEL_SEARCH=true
PONDER_CLOUD_WEIGHT=0.20
VETINARI_MODELS_CONFIG=
VETINARI_MODEL_DISCOVERY_RETRIES=2
VETINARI_MODEL_DISCOVERY_RETRY_DELAY=0.5

# ── GPU / VRAM ────────────────────────────────────────────────────────────────
VETINARI_GPU_VRAM_GB=32
VETINARI_CPU_OFFLOAD_GB=30

# ── Logging ───────────────────────────────────────────────────────────────────
VETINARI_LOG_LEVEL=INFO
VETINARI_STRUCTURED_LOGGING=true
VETINARI_VERSION=

# ── Miscellaneous ─────────────────────────────────────────────────────────────
VETINARI_STATE_DIR=
VETINARI_OUTPUTS_DIR=outputs
VETINARI_MAX_CONTEXT_TOKENS=4096
VETINARI_GIT_TIMEOUT=10
VETINARI_UPGRADE_AUTO_APPROVE=false
VETINARI_REFINE_THRESHOLD=0.70
VETINARI_SEARCH_BACKEND=duckduckgo
SEARXNG_URL=
EXPLAINABILITY_ENABLED=true
VETINARI_ALERT_WEBHOOK_URL=
VETINARI_RATE_LIMIT_REQUESTS=60
VETINARI_RATE_LIMIT_WINDOW=60
VETINARI_CORS_ORIGIN=
