# Original content preserved below for reference:
# NeMo Guardrails Configuration for Vetinari
# Uses local llama-cpp-python inference for guardrail model calls

models:
  - type: main
    engine: openai
    parameters:
      api_base: "local"
      model_name: "${GUARDRAIL_MODEL:-default}"

rails:
  input:
    flows:
      - check jailbreak
      - check toxic language
      - check prompt injection
  output:
    flows:
      - check toxic language
      - check sensitive data leakage

# Reduce latency for guardrail checks
parameters:
  max_tokens: 100
  temperature: 0.0
